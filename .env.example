# ── Required ──────────────────────────────────────────────────────────────────
# Get your FREE key at https://aistudio.google.com/apikey
# No credit card needed — just sign in with Google
GEMINI_API_KEY=AIzaSy...

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# Analyses allowed per user per day (free tier limit is ~1500/day total)
DAILY_LIMIT=10

# Max upload file size in MB
MAX_FILE_SIZE_MB=10

# App title shown in the browser
APP_TITLE=🔍 Free EDA Agent

# Gemini model — gemini-1.5-flash is free and fast
# Other free options: gemini-2.0-flash
GEMINI_MODEL=gemini-1.5-flash
